# LLM provider: groq, ollama, or hf
LLM_PROVIDER=groq

# Groq settings
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama settings
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434

# Hugging Face settings
HF_API_KEY=
HF_LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
HF_BASE_URL=https://router.huggingface.co/v1/chat/completions

# Embedding settings
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Retrieval settings
TOP_K_RAG=5
MAX_SQL_RETRIES=3
NEWS_COLLECTION=nepse_news

# Scraping settings
SCRAPE_DELAY_SEC=3
MAX_ARTICLES=5000
